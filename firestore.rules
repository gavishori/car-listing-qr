rules_version = '2';

// This project holds ONLY anonymous QR-scan counters for one car listing.
// No personal data is ever written here (no name, phone, email, or IP).
service cloud.firestore {
  match /databases/{database}/documents {

    match /carQrScans/{scanId} {
      // Anyone scanning the QR may create exactly one scan record with
      // only these two fields (+ the server-set timestamp).
      allow create: if request.resource.data.keys().hasOnly(['device', 'browser', 'ts'])
                    && request.resource.data.device is string
                    && request.resource.data.browser is string;

      // The dashboard reads aggregate counts and the recent list.
      allow read: if true;

      // Records are never edited or removed by clients.
      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
